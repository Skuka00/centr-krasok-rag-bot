        "responseBody": "<!doctype html>\n<html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Вход — RAG Admin</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Geologica:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n<style>\n*{margin:0;padding:0;box-sizing:border-box}\n:root{--bg:#080b14;--bd:rgba(255,255,255,0.08);--ac:#6c63ff;--ac2:#a855f7;--tx:#e8eaf6;--mu:rgba(232,234,246,0.45);--dg:#ff4d6d}\nbody{font-family:'Geologica',sans-serif;background:var(--bg);min-height:100vh;display:flex;align-items:center;justify-content:center;color:var(--tx)}\n.orb{position:fixed;border-radius:50%;filter:blur(80px);pointer-events:none}\n.o1{width:500px;height:500px;background:radial-gradient(circle,rgba(108,99,255,0.18),transparent 70%);top:-100px;left:-100px}\n.o2{width:400px;height:400px;background:radial-gradient(circle,rgba(168,85,247,0.15),transparent 70%);bottom:-80px;right:-80px}\n.card{position:relative;background:rgba(255,255,255,0.03);backdrop-filter:blur(24px);border:1px solid var(--bd);border-radius:24px;padding:48px 40px;width:100%;max-width:420px;box-shadow:0 32px 80px rgba(0,0,0,0.4)}\n.logo{text-align:center;margin-bottom:36px}\n.li{width:64px;height:64px;background:linear-gradient(135deg,var(--ac),var(--ac2));border-radius:18px;display:inline-flex;align-items:center;justify-content:center;margin-bottom:16px;box-shadow:0 8px 32px rgba(108,99,255,0.35);color:#fff;font-size:28px;font-weight:700}\nh1{font-size:24px;font-weight:600}\n.sub{font-size:14px;color:var(--mu);margin-top:6px}\nlabel{display:block;font-size:12px;font-weight:500;color:var(--mu);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}\ninput{width:100%;padding:14px 16px;background:rgba(255,255,255,0.05);border:1px solid var(--bd);border-radius:12px;color:var(--tx);font-family:inherit;font-size:15px;outline:none;transition:all .2s}\ninput:focus{border-color:var(--ac);background:rgba(108,99,255,0.08);box-shadow:0 0 0 3px rgba(108,99,255,0.15)}\nbutton{width:100%;padding:15px;background:linear-gradient(135deg,var(--ac),var(--ac2));border:none;border-radius:12px;color:#fff;font-family:inherit;font-size:15px;font-weight:600;cursor:pointer;margin-top:20px}\nbutton:hover{transform:translateY(-1px);box-shadow:0 12px 36px rgba(108,99,255,0.45)}\n.err{display:none;background:rgba(255,77,109,0.1);border:1px solid rgba(255,77,109,0.3);border-radius:10px;padding:12px 16px;font-size:13px;color:var(--dg);margin-bottom:16px;text-align:center}\n.show .err{display:block}\n</style></head><body>\n<div class=\"orb o1\"></div><div class=\"orb o2\"></div>\n<div class=\"card\">\n<div class=\"logo\"><div class=\"li\">🔒</div>\n<h1>RAG Admin Panel</h1><p class=\"sub\">Управление ботом Центра Красок</p></div>\n<form method=\"POST\" action=\"/webhook/admin-login\" id=\"lf\">\n<div class=\"err\">Неверный пароль</div>\n<label>Пароль</label>\n<input type=\"password\" name=\"password\" placeholder=\"••••••••\" required autofocus>\n<button type=\"submit\">Войти →</button>\n</form></div>\n<script>if(new URLSearchParams(location.search).get('e')==='1')document.getElementById('lf').classList.add('show');</script>\n</body></html>",
