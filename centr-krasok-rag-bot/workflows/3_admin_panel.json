        "jsCode": "\nconst item = $input.first();\nconst text = item.json.text || item.json.data || item.json.content || '';\nconst binary = item.binary && (item.binary.file || item.binary.data) || {};\nconst filename = binary.fileName || item.json.filename || 'document.txt';\nconst ext = (filename.split('.').pop() || 'txt').toLowerCase();\n\nif (!text || text.length < 50) {\n  throw new Error('Текст слишком короткий: ' + text.length);\n}\n\nconst cleanText = text.replace(/\\s+/g, ' ').replace(/[\\u0000-\\u001F\\u007F]/g, '').trim();\n\nconst CHUNK_SIZE = 800;\nconst OVERLAP = 80;\nconst MAX_CHUNKS = 50;\nconst MIN_STEP = 400;\n\nconst chunks = [];\nlet i = 0;\nlet iter = 0;\n\nwhile (i < cleanText.length && chunks.length < MAX_CHUNKS) {\n  iter++;\n  if (iter > 200) throw new Error('Loop guard: ' + iter);\n  \n  let end = Math.min(i + CHUNK_SIZE, cleanText.length);\n  \n  if (end < cleanText.length) {\n    const lastDot = cleanText.lastIndexOf('.', end);\n    const lastSp = cleanText.lastIndexOf(' ', end);\n    const cut = Math.max(lastDot, lastSp);\n    if (cut > i + MIN_STEP) end = cut + 1;\n  }\n  \n  const piece = cleanText.slice(i, end).trim();\n  \n  if (piece.length >= 80 && /[а-яА-Яa-zA-Z0-9]/.test(piece)) {\n    chunks.push(piece);\n  }\n  \n  const nextI = end - OVERLAP;\n  i = (nextI > i) ? nextI : (i + MIN_STEP);\n  \n  if (end >= cleanText.length) break;\n}\n\nif (chunks.length === 0) throw new Error('Нет валидных чанков');\n\nreturn chunks.map((content, idx) => ({\n  json: {\n    content,\n    chunk_index: idx,\n    total_chunks: chunks.length,\n    filename,\n    file_type: ext\n  }\n}));\n"
      },
