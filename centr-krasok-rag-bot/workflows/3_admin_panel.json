    {
      "parameters": {
        "jsCode": "const stats = $('Get Stats').first().json;\nconst docs = $('Get Documents3').all().map(r => r.json).filter(r => r && r.id);\nconst versions = $('Get Prompt Versions').all().map(r => r.json).filter(r => r && r.id);\n\nfunction esc(s){\n  return String(s == null ? '' : s)\n    .replace(/&/g,'&amp;')\n    .replace(/</g,'&lt;')\n    .replace(/>/g,'&gt;')\n    .replace(/\"/g,'&quot;')\n    .replace(/'/g,'&#39;');\n}\n\nfunction fmtDate(d){\n  if(!d) return '—';\n  return new Date(d).toLocaleString('ru-RU',{\n    day:'2-digit',month:'2-digit',year:'numeric',\n    hour:'2-digit',minute:'2-digit'\n  });\n}\n\nconst isOn = stats.is_enabled === true || stats.is_enabled === 't' || stats.is_enabled === 'true';\n\nconst docsRows = docs.length === 0\n  ? '<tr><td colspan=\"5\" style=\"padding:40px;text-align:center;color:rgba(232,234,246,0.35)\">Документов пока нет — загрузите первый файл</td></tr>'\n  : docs.map(d => '<tr><td><span class=\"iid\">#' + d.id + '</span></td><td><div style=\"font-weight:600\">' + esc(d.filename) + '</div><div style=\"font-size:11px;color:var(--mu);margin-top:2px\">' + esc(d.file_type || '—') + '</div></td><td><span class=\"cbadge\">' + (d.chunks_count || 0) + ' чанков</span></td><td><span style=\"font-size:12px;color:var(--mu)\">' + fmtDate(d.uploaded_at) + '</span></td><td><button class=\"abtn abtn-del\" data-id=\"' + d.id + '\" data-name=\"' + esc(d.filename) + '\">🗑</button></td></tr>').join('');\n\nconst versionsRows = versions.length === 0\n  ? '<div style=\"padding:24px;text-align:center;color:var(--mu);font-size:13px\">История пока пуста</div>'\n  : versions.map(v => '<div class=\"ver-item\"><div style=\"flex:1\"><div style=\"font-size:12px;color:var(--mu);margin-bottom:4px\">' + fmtDate(v.created_at) + (v.note ? ' · ' + esc(v.note) : '') + '</div><div style=\"font-size:13px;line-height:1.5\">' + esc(v.preview || '') + '</div></div><button class=\"btn btng\" data-rollback=\"' + v.id + '\">↶ Откатить</button></div>').join('');\n\nconst html = [\n'<!doctype html>',\n'<html lang=\"ru\"><head>',\n'<meta charset=\"utf-8\">',\n'<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">',\n'<title>RAG Admin</title>',\n'<link href=\"https://fonts.googleapis.com/css2?family=Geologica:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\">',\n'<style>',\n'*{margin:0;padding:0;box-sizing:border-box}',\n':root{--bg:#080b14;--bg2:#0d1120;--sf:rgba(255,255,255,0.04);--sf2:rgba(255,255,255,0.07);--bd:rgba(255,255,255,0.08);--bd2:rgba(255,255,255,0.15);--ac:#6c63ff;--ac2:#a855f7;--ac3:#06b6d4;--tx:#e8eaf6;--mu:rgba(232,234,246,0.45);--dg:#ff4d6d;--ok:#00d68f}',\n'body{font-family:Geologica,sans-serif;background:var(--bg);color:var(--tx);min-height:100vh}',\n'.orb{position:fixed;border-radius:50%;filter:blur(100px);pointer-events:none;z-index:0}',\n'.o1{width:600px;height:600px;background:radial-gradient(circle,rgba(108,99,255,0.12),transparent 70%);top:-200px;left:-200px}',\n'.o2{width:500px;height:500px;background:radial-gradient(circle,rgba(168,85,247,0.1),transparent 70%);bottom:-100px;right:-100px}',\n'.app{position:relative;z-index:1;display:flex;min-height:100vh}',\n'.sb{width:255px;background:rgba(6,9,18,0.97);border-right:1px solid var(--bd);backdrop-filter:blur(20px);display:flex;flex-direction:column;position:sticky;top:0;height:100vh}',\n'.sl{padding:26px 22px 18px;display:flex;align-items:center;gap:12px;border-bottom:1px solid var(--bd)}',\n'.lm{width:38px;height:38px;background:linear-gradient(135deg,var(--ac),var(--ac2));border-radius:11px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(108,99,255,0.35);color:#fff;font-weight:700;font-size:18px}',\n'.lt{font-size:14px;font-weight:700}.ls{font-size:11px;color:var(--mu)}',\n'.snav{padding:14px 10px;flex:1}',\n'.nl{font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:var(--mu);padding:0 12px;margin:14px 0 6px}',\n'.ni{display:flex;align-items:center;gap:11px;padding:10px 